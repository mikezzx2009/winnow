# Winnow 配置模板 —— 复制为 .env 后填入真实值。
# .env 已在 .gitignore 中, 绝不提交。所有密钥只放这里, 不落数据库、不打日志。

# ========== 126 邮箱 (收信 IMAP / 发信 SMTP 共用同一「授权码」) ==========
# EMAIL_126: 你的 126 邮箱完整地址
# IMAP_AUTH_CODE: 客户端授权码, 不是网页登录密码! (获取步骤见 README)
EMAIL_126=your_name@126.com
IMAP_AUTH_CODE=your_126_client_auth_code

# 下面这几项一般无需修改
IMAP_HOST=imap.126.com
IMAP_PORT=993
SMTP_HOST=smtp.126.com
SMTP_PORT=465

# ========== 转发目标 ==========
FORWARD_TO=you@example.com
# 转发邮件标题前缀 (带引号以保留末尾空格); 方便在 iCloud 里一眼识别并做过滤
SUBJECT_PREFIX="[Winnow] "

# ========== MiniMax (Token Plan 订阅 Key, 形如 sk-sp-xxxx) ==========
# 订阅 Key 与开放平台「按量付费」Key 是两套、额度不互通。此处填订阅 Key。
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_API_KEY=sk-sp-xxxxxxxxxxxxxxxx
MINIMAX_MODEL=MiniMax-M2.5

# ========== 判断 / 限速 (Phase 1 就位, 由后续管线使用) ==========
# 重要性阈值: 模型判为「不重要」但置信度低于此值时, 仍倾向转发 (漏判代价更大)
IMPORTANCE_THRESHOLD=0.75
# 相邻两封转发之间的最小间隔秒数 (规避 126 反垃圾限速)
FORWARD_INTERVAL_SECONDS=5
# 每日转发上限, 超过后排队至次日 (而非硬发)
DAILY_FORWARD_LIMIT=200

# ========== 存储 / 加密 (Phase 2 使用) ==========
DATABASE_URL=sqlite:///winnow.db
# FERNET_KEY: Phase 2 做邮箱绑定页、需把授权码加密入库时使用。
# 生成方法: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# FERNET_KEY=
